# Unity
# Basis: github/gitignore Unity template

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
*.log

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta


# Uncomment this line if you wish to ignore the asset store tools plugin
/[Aa]ssets/AssetStoreTools*

# Addressables
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Rider / VS Code
.idea/
.vscode/
.vs/
.gradle/
ExportedObj/
.consulo/
[Aa]ssets/Plugins/Editor/JetBrains*

# OS
.DS_Store
Thumbs.db

# Auto-generated solution and project files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Tool-Projekt
Tools/obj/
Tools/bin/
!Tools/lint.csproj

# Unity generated meta files for IDE/db artifacts
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crash reports
sysinfo.txt

# Burst AOT
/BurstDebugInformation_DoNotShip/
